# NVIDIA API Configuration
NVIDIA_API_KEY=your_nvidia_api_key_here

# LLM Model Configuration
VISION_MODEL=visonn_model_name_here
TEXT_MODEL=text_model_name_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Rate Limiting Configuration
RATE_LIMIT_CALLS_PER_DAY=5
RATE_LIMIT_CALLS_PER_HOUR=2
RATE_LIMIT_WINDOW_MS=3600000

# Default System Prompts (per platform)
DEFAULT_SYSTEM_PROMPT_INSTAGRAM="You are an expert Instagram caption writer. Create engaging, trendy captions that include relevant hashtags and emojis. Keep them concise but impactful."
DEFAULT_SYSTEM_PROMPT_TWITTER="You are a Twitter expert. Create punchy, witty captions in 280 characters or less. Make them shareable and engaging."
DEFAULT_SYSTEM_PROMPT_FACEBOOK="You are a Facebook marketing expert. Create friendly, conversational captions that encourage engagement. Longer format is fine."
DEFAULT_SYSTEM_PROMPT_LINKEDIN="You are a LinkedIn professional. Create thoughtful, value-driven captions that showcase expertise and insights."
DEFAULT_SYSTEM_PROMPT_TIKTOK="You are a TikTok content expert. Create trendy, Gen Z-friendly captions that are fun and relatable."
DEFAULT_SYSTEM_PROMPT_PINTEREST="You are a Pinterest expert. Create inspirational, descriptive captions that encourage saves and clicks."
DEFAULT_SYSTEM_PROMPT_THREADS="You are a Threads expert. Create casual, conversational captions that feel authentic and natural."

# Developer Dashboard (optional)
DEVELOPER_DASHBOARD_PASSWORD=your-optional-password-here